# -----------------------------------------------------------------------------
# Medipal Environment Variables Template
# -----------------------------------------------------------------------------
# Copy this file to '.env' and replace the placeholder values with your actual
# keys. Docker Compose will automatically load variables from the '.env' file.
# -----------------------------------------------------------------------------

# ==========================================
# Backend Settings
# ==========================================

# Application Environment (development, test, production)
APP_ENV=development

# Database Connection
# Used by FastAPI, Alembic, and Docker Compose
# Format: postgresql+asyncpg://user:password@host:port/dbname
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/graduation_db

# Security & Authentication
# Generate a strong secret key (e.g., using `openssl rand -hex 32`)
SECRET_KEY=your_super_secret_jwt_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS Allowed Origins (JSON array or comma-separated)
CORS_ORIGINS=["http://localhost:3000"]

# ==========================================
# AI Provider Keys
# ==========================================

# Google Gemini API Key (Required for main LLM operations)
GOOGLE_API_KEY=your_google_api_key_here

# Cohere API Key (Required for RAG document reranking)
COHERE_API_KEY=your_cohere_api_key_here

# Tavily API Key (Optional: for web search capabilities)
TAVILY_API_KEY=your_tavily_api_key_here

# ==========================================
# Frontend Settings
# ==========================================

# Base URL for the frontend to communicate with the backend (used by browser)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Base URL for server-side fetches (used in Docker network)
API_INTERNAL_URL=http://backend:8000

# Secret used to encrypt/decrypt Next.js edge session cookies
# Generate a strong key (e.g., using `openssl rand -hex 32`)
SESSION_SECRET=your_super_secret_session_key_here
